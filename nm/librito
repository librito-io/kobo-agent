# Librito NickelMenu config — copy to /mnt/onboard/.adds/nm/librito
#
# Relabels the NickelMenu bottom-bar tab to "Librito" (hardware-verified on
# Nickel 4.45). A `main`-location tab opens a submenu with the Step-4 status
# surface ("Sync now" / "Status" / "About") plus "Pair".
#
# WARNING: `experimental:` directives are flagged by NickelMenu as possibly
# unstable across versions. Pin to the tested NickelMenu version (v0.6.0) and
# re-verify after any NickelMenu or firmware update. The menu item id (15505)
# is from the spec's verified example — confirm the live id on-device (Task 11).
#
# The `cmd_output` items run the agent and show its stdout in a native Nickel
# dialog (hardware-proven). The timeout is in ms. "Sync now" performs a network
# sync, so its timeout (30000) must comfortably exceed a worst-case sync — this
# is HARDWARE-OWED (verify cmd_output tolerates a ~15s blocking command and that
# 30000 ms is honored; if not, fall back to a cmd_spawn fire-and-forget). The
# read-only "Status"/"About" return instantly, so 2000 ms is ample.

experimental :menu_main_15505_label :Librito

menu_item :main :Sync now :cmd_output :30000 :/mnt/onboard/.adds/librito/kobo-sync sync-now
menu_item :main :Status :cmd_output :2000 :/mnt/onboard/.adds/librito/kobo-sync status
menu_item :main :About :cmd_output :2000 :/mnt/onboard/.adds/librito/kobo-sync about
menu_item :main :Pair Librito :cmd_spawn :quiet :/mnt/onboard/.adds/librito/kobo-sync pair
